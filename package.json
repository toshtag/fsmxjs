{
  "name": "fsmxjs",
  "version": "0.1.0",
  "description": "Minimal, framework-agnostic finite state machine library for TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest typecheck --run",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build"
  },
  "keywords": [
    "fsm",
    "state-machine",
    "finite-state-machine",
    "typescript",
    "framework-agnostic"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.8.0",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.0"
  }
}
