{
  "name": "@fsmxjs/async",
  "version": "1.0.2",
  "description": "Async task helpers for fsmxjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "cd ../.. && node_modules/.bin/tsup --config packages/async/tsup.config.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "fsm",
    "state-machine",
    "finite-state-machine",
    "typescript",
    "async"
  ],
  "author": "toshtag (https://github.com/toshtag)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "fsmxjs": ">=1.3.0"
  }
}
